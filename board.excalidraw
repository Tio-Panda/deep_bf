    {
      "id": "MqWB7PPdtu7LPagR0LO6X",
      "type": "text",
      "x": 1050.2550910041705,
      "y": -647.0610416062818,
      "width": 521.6421508789062,
      "height": 455,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
